# Exa AI API Key (Required)
# Get your API key from: https://exa.ai/
EXA_API_KEY=your_exa_api_key_here

# Debug logging (Optional)
# Set to 'true' to enable detailed logging
DEBUG=false

# Enabled Tools (Optional)
# Comma-separated list of tools to enable
# Available tools:
#   - web_search_exa (enabled by default)
#   - web_fetch_exa (enabled by default)
#   - web_search_advanced_exa
#   - get_code_context_exa (deprecated)
#   - company_research_exa (deprecated)
#   - people_search_exa (deprecated)
#   - linkedin_search_exa (deprecated)
#   - deep_researcher_start (deprecated)
#   - deep_researcher_check (deprecated)
#
# Example: ENABLED_TOOLS=web_search_exa,web_fetch_exa
# Leave empty or comment out to use defaults
# ENABLED_TOOLS=

# OpenAI Apps SDK domain verification token (Optional)
# Required only when submitting this MCP server to the ChatGPT Apps Directory /
# Codex Plugin Directory. OpenAI's submission UI generates a token and fetches
# it from https://<your-domain>/.well-known/openai-apps-challenge to verify
# domain ownership. Comma- or newline-separated list of tokens is supported
# during rotation.
# OPENAI_APPS_CHALLENGE_TOKEN=

